#!/usr/bin/env python3
"""Tiny jq fallback used by LOZO shell scripts.

This only supports the expression shape used in upstream `lozo.sh`:
`{"SNLI": 3, ...}["$TASK"] // 2`
"""

from __future__ import annotations

import ast
import re
import sys


def _usage() -> int:
    sys.stderr.write(
        "runtime_shims/bin/jq supports only: jq -n "
        "'{\"KEY\": N, ...}[\"lookup\"] // default'\n"
    )
    return 2


def main() -> int:
    if len(sys.argv) != 3 or sys.argv[1] != "-n":
        return _usage()

    expr = sys.argv[2].strip()
    m = re.match(
        r'^\s*(\{.*\})\s*\[\s*["\']([^"\']+)["\']\s*\]\s*//\s*(-?\d+)\s*$',
        expr,
    )
    if not m:
        return _usage()

    table_raw, key, default_raw = m.groups()
    try:
        table = ast.literal_eval(table_raw)
        if not isinstance(table, dict):
            return _usage()
        default = int(default_raw)
    except Exception:
        return _usage()

    value = table.get(key, default)
    try:
        sys.stdout.write(f"{int(value)}\n")
    except Exception:
        return _usage()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
